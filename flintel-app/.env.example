# ── Flintel backend config ────────────────────────────────────────────
# Copy to .env and fill in. Everything except the app still boots without
# keys — but the scan runs in HEURISTIC mode and reports are marked demo=true.

# Real analysis (company profiling, thread scoring, comment drafts).
# Without this, scans still return REAL Reddit data but no AI scoring/summaries.
ANTHROPIC_API_KEY=

# Model string — verify the current one at https://docs.claude.com/en/api
# A wrong value won't crash the app; the LLM layer just falls back to heuristics.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Reddit is read via public JSON with this User-Agent. For heavier volume,
# register a Reddit app and (later) add OAuth — see README.
REDDIT_USER_AGENT=web:flintel-market-scan:v1.0 (contact hello@getflintel.com)

# Server
PORT=8000
LOG_LEVEL=INFO
REPORT_WAIT_S=60          # how long GET /report waits for a slow scan
FLINTEL_DB=./flintel.db   # SQLite file path
